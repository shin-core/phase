{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Phase",
  "version": "0.35.0",
  "identifier": "rs.phase.app",
  "build": {
    "frontendDist": "../bootstrap/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:bootstrap"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "label": "main",
        "title": "phase.rs",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://cards.scryfall.io https://backs.scryfall.io; connect-src 'self' https://phase-rs.dev https://app.phase-rs.dev https://preview.phase-rs.dev"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://data.phase-rs.dev/desktop/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4MzI0NUJGOEIyODNFNjIKUldSaVBpaUx2MFV5ZU4zNk9vWGtJQVN1eTRmc2Rvc3pDc2JvWWM4TTlua1dWQ1g3eGlFN1NQaFEK"
    }
  }
}
